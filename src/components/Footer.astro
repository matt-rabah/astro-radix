---
const currentYear = new Date().getFullYear();

type FooterLink = {
  name: string;
  path: string;
};

type FooterSection = {
  title: string;
  links: FooterLink[];
};

const footerSections: FooterSection[] = [
  {
    title: "Company",
    links: [
      { name: "About", path: "/about/" },
      { name: "Services", path: "/services/" },
      { name: "Work", path: "/work/" },
      { name: "Contact", path: "/contact/" },
    ],
  },
  {
    title: "Services",
    links: [
      {
        name: "CX Systems Diagnostic",
        path: "/services/cx-systems-diagnostic/",
      },
      {
        name: "Lifecycle Risk Review",
        path: "/services/lifecycle-risk-review/",
      },
      { name: "CRM Workflow Audit", path: "/services/crm-workflow-audit/" },
      {
        name: "AI Service Readiness Review",
        path: "/services/ai-service-readiness/",
      },
    ],
  },
  {
    title: "Insights",
    links: [
      { name: "Research", path: "/research/" },
      { name: "Frameworks", path: "/frameworks/" },
      { name: "Blog", path: "/blog/" },
      { name: "Field Notes", path: "/field-notes/" },
    ],
  },
  {
    title: "Connect",
    links: [
      { name: "Start a Conversation", path: "/contact/" },
      { name: "LinkedIn", path: "https://www.linkedin.com/" },
      { name: "Email", path: "mailto:hello@cadencelab.co" },
    ],
  },
];
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__top">
      <div class="site-footer__brand-block">
        <a href="/" class="site-footer__brand" aria-label="Cadence Lab home">
          <span>Cadence</span>
          <span class="site-footer__brand-muted">Lab</span>
        </a>

        <p class="site-footer__statement">
          Customer experience operating systems for teams preparing for a more
          automated, AI-enabled service environment.
        </p>
      </div>

      <a href="/contact/" class="site-footer__cta">Start a conversation</a>
    </div>

    <nav class="site-footer__nav" aria-label="Footer navigation">
      {
        footerSections.map((section) => (
          <section class="site-footer__section">
            <h2 class="site-footer__section-title">{section.title}</h2>

            <ul class="site-footer__list">
              {section.links.map((link) => (
                <li>
                  <a href={link.path} class="site-footer__link">
                    {link.name}
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </nav>

    <div class="site-footer__bottom">
      <p class="site-footer__meta">
        © {currentYear} Cadence Lab. All rights reserved.
      </p>

      <div class="site-footer__legal">
        <a href="/privacy/" class="site-footer__legal-link">Privacy</a>
        <a href="/terms/" class="site-footer__legal-link">Terms</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding-block: var(--space-10);
    color: var(--color-footer-text);
    background: var(--color-footer-bg);
    font-family: var(--font-sans);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .site-footer__inner {
    width: min(100% - 4rem, var(--container-max));
    margin-inline: auto;
  }

  .site-footer__top {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-6);
    margin-bottom: var(--space-16);
  }

  .site-footer__brand-block {
    max-width: 42rem;
  }

  .site-footer__brand {
    display: inline-flex;
    align-items: baseline;
    gap: 0.25rem;
    margin-bottom: var(--space-4);
    font-family: var(--font-sans);
    font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl));
    font-weight: var(--weight-semibold);
    line-height: 1;
    letter-spacing: var(--tracking-snug);
    color: var(--color-footer-text);
  }

  .site-footer__brand-muted {
    color: var(--color-footer-muted);
  }

  .site-footer__statement {
    max-width: 54ch;
    margin: 0;
    font-family: var(--font-serif-text);
    font-size: clamp(var(--text-lg), 2vw, var(--text-xl));
    font-weight: var(--weight-normal);
    line-height: var(--leading-relaxed);
    letter-spacing: var(--tracking-snug);
    color: #d7d9d8;
  }

  .site-footer__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    padding-inline: var(--space-3);
    border: 1px solid rgb(255 255 255 / 22%);
    border-radius: var(--radius-pill);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-footer-text);
    transition:
      color 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease;
    white-space: nowrap;
  }

  .site-footer__cta:hover,
  .site-footer__cta:focus-visible {
    border-color: var(--color-footer-text);
    background-color: rgb(255 255 255 / 8%);
  }

  .site-footer__nav {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 2.5rem 2rem;
    margin-bottom: var(--space-16);
  }

  .site-footer__section-title {
    max-width: none;
    margin: 0 0 var(--space-2);
    font-family: var(--font-accent);
    font-size: 0.6875rem;
    font-weight: var(--weight-bold);
    line-height: 1.25;
    letter-spacing: 0.125rem;
    text-transform: uppercase;
    color: var(--color-footer-muted);
  }

  .site-footer__list {
    display: grid;
    gap: 0.125rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .site-footer__link {
    display: inline-flex;
    padding-block: 0.375rem;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    line-height: 1.35;
    color: var(--color-footer-muted);
    transition: color 0.2s ease;
  }

  .site-footer__link:hover,
  .site-footer__link:focus-visible {
    color: var(--color-footer-text);
  }

  .site-footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-footer-border);
  }

  .site-footer__meta {
    margin: 0;
    font-size: var(--text-xs);
    line-height: 1.4;
    color: var(--color-footer-subtle);
  }

  .site-footer__legal {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .site-footer__legal-link {
    font-size: var(--text-xs);
    color: var(--color-footer-subtle);
    transition: color 0.2s ease;
  }

  .site-footer__legal-link:hover,
  .site-footer__legal-link:focus-visible {
    color: var(--color-footer-text);
  }

  @media (max-width: 768px) {
    .site-footer {
      padding-block: var(--space-8);
    }

    .site-footer__inner {
      width: min(100% - 2rem, var(--container-max));
    }

    .site-footer__top {
      flex-direction: column;
      align-items: flex-start;
      margin-bottom: var(--space-10);
    }

    .site-footer__nav {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      margin-bottom: var(--space-10);
    }

    .site-footer__bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 480px) {
    .site-footer__nav {
      grid-template-columns: 1fr;
    }
  }
</style>
