---
const currentYear = new Date().getFullYear();

const footerSections = [
  {
    title: "Company",
    links: [
      { name: "About", path: "/about/" },
      { name: "Work", path: "/work/" },
      { name: "Methods", path: "/methods/" },
      { name: "Contact", path: "/contact/" },
    ],
  },
  {
    title: "Services",
    links: [
      { name: "CX Diagnosis", path: "/services/cx-diagnosis/" },
      {
        name: "Operating Model Design",
        path: "/services/operating-model-design/",
      },
      { name: "CRM and Customer Data", path: "/services/crm-customer-data/" },
      {
        name: "Human-in-the-Loop AI",
        path: "/services/human-in-the-loop-ai/",
      },
    ],
  },
  {
    title: "Insights",
    links: [
      { name: "Research Notes", path: "/research/" },
      { name: "Blog", path: "/blog/" },
      { name: "Frameworks", path: "/frameworks/" },
      { name: "Field Notes", path: "/field-notes/" },
    ],
  },
  {
    title: "Connect",
    links: [
      { name: "Start a Conversation", path: "/contact/" },
      { name: "LinkedIn", path: "https://www.linkedin.com/" },
      { name: "Email", path: "mailto:hello@cadencelab.com" },
    ],
  },
];
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__top">
      <div class="site-footer__brand-block">
        <a href="/" class="site-footer__brand" aria-label="Cadence Lab home">
          <span>Cadence</span>
          <span class="site-footer__brand-muted">Lab</span>
        </a>

        <p class="site-footer__statement">
          Customer experience work for teams that need clearer systems, better
          operating rhythm, and practical human-in-the-loop AI.
        </p>
      </div>

      <div class="site-footer__social">
        <a href="https://www.linkedin.com/" class="site-footer__social-link">
          LinkedIn
        </a>
      </div>
    </div>

    <nav class="site-footer__nav" aria-label="Footer navigation">
      {
        footerSections.map((section) => (
          <div class="site-footer__section">
            <h2 class="site-footer__section-title">{section.title}</h2>

            <ul class="site-footer__list">
              {section.links.map((link) => (
                <li>
                  <a href={link.path} class="site-footer__link">
                    {link.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </nav>

    <div class="site-footer__bottom">
      <p class="site-footer__meta">© {currentYear} Cadence Lab</p>

      <div class="site-footer__legal">
        <a href="/privacy/" class="site-footer__legal-link">Privacy</a>
        <a href="/terms/" class="site-footer__legal-link">Terms</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: #000504;
    color: #ffffff;
    padding-block: 5rem;
    font-family: var(--font-sans);
  }

  .site-footer__inner {
    width: min(100% - 4rem, var(--container-max, 1200px));
    margin-inline: auto;
  }

  .site-footer__top {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: var(--space-6);
    margin-bottom: var(--space-16);
  }

  .site-footer__brand-block {
    max-width: 44rem;
  }

  .site-footer__brand {
    display: inline-flex;
    align-items: baseline;
    gap: 0.25rem;
    margin-bottom: var(--space-4);
    font-family: var(--font-sans);
    font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl));
    font-weight: var(--weight-semibold);
    line-height: 1;
    letter-spacing: var(--tracking-snug);
    color: #ffffff;
  }

  .site-footer__brand-muted {
    color: #989a99;
  }

  .site-footer__statement {
    max-width: 52ch;
    margin: 0;
    font-family: var(--font-serif-text);
    font-size: clamp(var(--text-lg), 2vw, var(--text-xl));
    line-height: var(--leading-relaxed);
    color: #d7d9d8;
  }

  .site-footer__social {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .site-footer__social-link {
    padding-block: 0.5rem;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: #989a99;
    transition: color 0.2s ease;
  }

  .site-footer__social-link:hover,
  .site-footer__social-link:focus-visible {
    color: #ffffff;
  }

  .site-footer__nav {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 2.5rem 2rem;
    margin-bottom: var(--space-16);
  }

  .site-footer__section-title {
    max-width: none;
    margin: 0 0 var(--space-2);
    font-family: var(--font-accent);
    font-size: 0.6875rem;
    font-weight: var(--weight-semibold);
    line-height: 1.2;
    letter-spacing: 0.125rem;
    text-transform: uppercase;
    color: #989a99;
  }

  .site-footer__list {
    display: grid;
    gap: 0.25rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .site-footer__link {
    display: inline-flex;
    padding-block: 0.375rem;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    line-height: 1.35;
    color: #989a99;
    transition: color 0.2s ease;
  }

  .site-footer__link:hover,
  .site-footer__link:focus-visible {
    color: #ffffff;
  }

  .site-footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding-top: var(--space-3);
    border-top: 1px solid rgb(255 255 255 / 10%);
  }

  .site-footer__meta {
    margin: 0;
    font-size: var(--text-xs);
    line-height: 1.4;
    color: #797c7b;
  }

  .site-footer__legal {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .site-footer__legal-link {
    font-size: var(--text-xs);
    color: #797c7b;
    transition: color 0.2s ease;
  }

  .site-footer__legal-link:hover,
  .site-footer__legal-link:focus-visible {
    color: #ffffff;
  }

  @media (max-width: 768px) {
    .site-footer {
      padding-block: 4rem;
    }

    .site-footer__inner {
      width: min(100% - 2rem, var(--container-max, 1200px));
    }

    .site-footer__top {
      flex-direction: column;
      align-items: start;
      margin-bottom: var(--space-10);
    }

    .site-footer__nav {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      margin-bottom: var(--space-10);
    }

    .site-footer__bottom {
      flex-direction: column;
      align-items: start;
    }
  }

  @media (max-width: 480px) {
    .site-footer__nav {
      grid-template-columns: 1fr;
    }
  }
</style>
