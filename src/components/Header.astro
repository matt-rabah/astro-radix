---
type NavItem = {
  name: string;
  path: string;
  children: NavItem[];
};

const navData: NavItem[] = [
  {
    name: "Home",
    path: "/",
    children: [],
  },
  {
    name: "About",
    path: "/about/",
    children: [],
  },
  {
    name: "Services",
    path: "/services/",
    children: [
      {
        name: "CX Systems Diagnostic",
        path: "/services/cx-systems-dx/",
        children: [],
      },
      {
        name: "Lifecycle Risk Review",
        path: "/services/lifecycle-risk/",
        children: [],
      },
      {
        name: "CRM Workflow Audit",
        path: "/services/crm-workflow/",
        children: [],
      },
      {
        name: "AI Service Readiness",
        path: "/services/ai-tools/",
        children: [],
      },
    ],
  },
  {
    name: "Insights",
    path: "/research/",
    children: [
      {
        name: "Research",
        path: "/research/",
        children: [],
      },
      {
        name: "Frameworks",
        path: "/frameworks/",
        children: [],
      },
      {
        name: "Blog",
        path: "/blog/",
        children: [],
      },
    ],
  },
  {
    name: "Work",
    path: "/work/",
    children: [],
  },
];

const utilityLink = {
  name: "Contact",
  path: "/contact/",
};
---

<header class="site-header" data-site-header>
  <div class="site-header__inner">
    <button
      class="site-header__menu-button"
      type="button"
      aria-label="Open navigation"
      aria-expanded="false"
      data-menu-toggle
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <a href="/" class="site-header__brand" aria-label="Cadence Lab home">
      <span>Cadence</span>
      <span class="site-header__brand-muted">Lab</span>
    </a>

    <div class="site-header__middle" data-menu-panel>
      <nav class="primary-nav" aria-label="Primary navigation">
        <ul class="primary-nav__list">
          {
            navData.map((item) => (
              <li class="primary-nav__item">
                <a
                  href={item.path}
                  class:list={[
                    "primary-nav__link",
                    item.children.length > 0
                      ? "primary-nav__link--has-menu"
                      : "",
                  ]}
                >
                  <span>{item.name}</span>

                  {item.children.length > 0 && (
                    <svg
                      class="primary-nav__chevron"
                      width="12"
                      height="12"
                      viewBox="0 0 12 12"
                      aria-hidden="true"
                    >
                      <path
                        d="M3 4.5L6 7.5L9 4.5"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  )}
                </a>

                {item.children.length > 0 && (
                  <div class="primary-nav__dropdown">
                    <ul class="primary-nav__dropdown-list">
                      {item.children.map((child) => (
                        <li>
                          <a
                            href={child.path}
                            class="primary-nav__dropdown-link"
                          >
                            {child.name}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
              </li>
            ))
          }
        </ul>
      </nav>

      <form class="site-search" action="/search/" method="get" role="search">
        <label class="site-search__label" for="site-search-input">Search</label>

        <div class="site-search__box">
          <svg
            class="site-search__icon"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              d="M21 21L15.8 15.8M18 10.5C18 14.6421 14.6421 18 10.5 18C6.35786 18 3 14.6421 3 10.5C3 6.35786 6.35786 3 10.5 3C14.6421 3 18 6.35786 18 10.5Z"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>

          <input
            id="site-search-input"
            class="site-search__input"
            type="search"
            name="q"
            placeholder="Search"
            autocomplete="off"
            data-site-search-input
          />

          <kbd class="site-search__shortcut" aria-hidden="true">/</kbd>
        </div>
      </form>
    </div>

    <div class="site-header__actions">
      <button
        class="theme-toggle"
        type="button"
        aria-label="Toggle dark mode"
        aria-pressed="false"
        data-theme-toggle
      >
        <svg
          class="theme-toggle__icon theme-toggle__icon--sun"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            d="M12 4V2M12 22V20M20 12H22M2 12H4M17.66 6.34L19.07 4.93M4.93 19.07L6.34 17.66M17.66 17.66L19.07 19.07M4.93 4.93L6.34 6.34M12 16.5A4.5 4.5 0 1 0 12 7.5A4.5 4.5 0 0 0 12 16.5Z"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>

        <svg
          class="theme-toggle__icon theme-toggle__icon--moon"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            d="M21 14.5A8.5 8.5 0 0 1 9.5 3A9 9 0 1 0 21 14.5Z"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </button>

      <a href={utilityLink.path} class="site-header__utility-link">
        {utilityLink.name}
      </a>
    </div>
  </div>
</header>

<script>
  const root = document.documentElement;

  const themeToggle = document.querySelector<HTMLElement>(
    "[data-theme-toggle]",
  );
  const searchInput = document.querySelector<HTMLInputElement>(
    "[data-site-search-input]",
  );
  const menuToggle = document.querySelector<HTMLElement>("[data-menu-toggle]");
  const menuPanel = document.querySelector<HTMLElement>("[data-menu-panel]");

  type Theme = "light" | "dark";

  const getStoredTheme = (): Theme | null => {
    const storedTheme = localStorage.getItem("cadence-theme");

    if (storedTheme === "dark" || storedTheme === "light") {
      return storedTheme;
    }

    return null;
  };

  const getPreferredTheme = (): Theme => {
    const storedTheme = getStoredTheme();

    if (storedTheme) {
      return storedTheme;
    }

    return window.matchMedia("(prefers-color-scheme: dark)").matches
      ? "dark"
      : "light";
  };

  const applyTheme = (theme: Theme): void => {
    const isDark = theme === "dark";

    root.classList.toggle("dark", isDark);
    themeToggle?.setAttribute("aria-pressed", String(isDark));
  };

  applyTheme(getPreferredTheme());

  themeToggle?.addEventListener("click", () => {
    const nextTheme: Theme = root.classList.contains("dark") ? "light" : "dark";

    localStorage.setItem("cadence-theme", nextTheme);
    applyTheme(nextTheme);
  });

  window.addEventListener("keydown", (event: KeyboardEvent) => {
    const activeElement = document.activeElement;
    const activeTag = activeElement?.tagName;
    const isTyping =
      activeTag === "INPUT" ||
      activeTag === "TEXTAREA" ||
      activeElement?.getAttribute("contenteditable") === "true";

    if (event.key === "/" && !isTyping) {
      event.preventDefault();
      searchInput?.focus();
    }

    if (event.key === "Escape") {
      searchInput?.blur();

      menuToggle?.setAttribute("aria-expanded", "false");
      menuPanel?.classList.remove("is-open");
    }
  });

  menuToggle?.addEventListener("click", () => {
    const isOpen = menuToggle.getAttribute("aria-expanded") === "true";

    menuToggle.setAttribute("aria-expanded", String(!isOpen));
    menuPanel?.classList.toggle("is-open", !isOpen);
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    border-bottom: var(--border-1) solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg-base) 96%, transparent);
    color: var(--color-text-base);
    font-family: var(--font-sans);
    backdrop-filter: blur(16px);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    width: min(100% - 2rem, var(--container-wide, 1440px));
    min-height: 48px;
    margin-inline: auto;
  }

  .site-header__brand {
    display: inline-flex;
    align-items: baseline;
    gap: 0.25rem;
    flex: 0 0 auto;
    font-size: var(--text-md);
    font-weight: var(--weight-semibold);
    line-height: 1;
    letter-spacing: var(--tracking-snug);
    color: var(--color-text-base);
    white-space: nowrap;
  }

  .site-header__brand-muted {
    color: var(--color-text-muted);
  }

  .site-header__middle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    flex: 1 1 auto;
    min-width: 0;
  }

  .primary-nav {
    display: flex;
    align-items: center;
    min-width: 0;
  }

  .primary-nav__list {
    display: flex;
    align-items: center;
    gap: 0.125rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .primary-nav__item {
    position: relative;
  }

  .primary-nav__link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    min-height: 36px;
    padding-inline: 0.75rem;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    line-height: 1;
    color: var(--color-text-muted);
    transition:
      color 0.2s ease,
      background-color 0.2s ease;
  }

  .primary-nav__link:hover,
  .primary-nav__link:focus-visible,
  .primary-nav__item:hover > .primary-nav__link,
  .primary-nav__item:focus-within > .primary-nav__link {
    color: var(--color-text-base);
    background: var(--color-bg-surface);
  }

  .primary-nav__chevron {
    flex: 0 0 auto;
    transition: transform 0.2s ease;
  }

  .primary-nav__item:hover .primary-nav__chevron,
  .primary-nav__item:focus-within .primary-nav__chevron {
    transform: rotate(180deg);
  }

  .primary-nav__dropdown {
    position: absolute;
    top: calc(100% + 0.375rem);
    left: 0;
    min-width: 18rem;
    padding: 0.5rem;
    border: var(--border-1) solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg-base);
    box-shadow: 0 18px 48px rgb(0 5 4 / 10%);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-0.25rem);
    transition:
      opacity 0.16s ease,
      visibility 0.16s ease,
      transform 0.16s ease;
  }

  .primary-nav__item:hover > .primary-nav__dropdown,
  .primary-nav__item:focus-within > .primary-nav__dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .primary-nav__dropdown-list {
    display: grid;
    gap: 0.125rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .primary-nav__dropdown-link {
    display: block;
    padding: 0.75rem;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    line-height: 1.25;
    color: var(--color-text-base);
    transition:
      color 0.2s ease,
      background-color 0.2s ease;
  }

  .primary-nav__dropdown-link:hover,
  .primary-nav__dropdown-link:focus-visible {
    color: var(--color-accent);
    background: var(--color-bg-surface);
  }

  .site-search {
    flex: 0 0 auto;
    margin: 0;
  }

  .site-search__label {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
  }

  .site-search__box {
    position: relative;
    display: flex;
    align-items: center;
    width: 200px;
    height: 36px;
    color: var(--color-text-muted);
  }

  .site-search__icon {
    position: absolute;
    left: 0.875rem;
    pointer-events: none;
  }

  .site-search__input {
    width: 100%;
    height: 36px;
    padding: 0.5rem 2.25rem 0.5rem 2.5rem;
    border: 0;
    border-radius: 40px;
    outline: none;
    background: var(--color-bg-surface);
    color: var(--color-text-base);
    font-size: var(--text-sm);
    line-height: 1;
    transition:
      background-color 0.2s ease,
      box-shadow 0.2s ease,
      width 0.2s ease;
  }

  .site-search__input::placeholder {
    color: var(--color-text-muted);
  }

  .site-search__input:focus {
    background: var(--color-bg-base);
    box-shadow:
      0 0 0 1px var(--color-border-strong),
      0 0 0 4px color-mix(in srgb, var(--color-accent) 12%, transparent);
  }

  .site-search__shortcut {
    position: absolute;
    right: 0.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.35rem;
    height: 1.35rem;
    border-radius: 8px;
    background: var(--color-bg-base);
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: var(--weight-medium);
    line-height: 1;
    box-shadow: inset 0 0 0 1px var(--color-border);
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex: 0 0 auto;
  }

  .theme-toggle,
  .site-header__menu-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    padding: 0;
    border: 0;
    border-radius: var(--radius-md);
    background: transparent;
    color: var(--color-text-muted);
    transition:
      color 0.2s ease,
      background-color 0.2s ease;
  }

  .theme-toggle:hover,
  .theme-toggle:focus-visible,
  .site-header__menu-button:hover,
  .site-header__menu-button:focus-visible {
    color: var(--color-text-base);
    background: var(--color-bg-surface);
  }

  .theme-toggle__icon--moon {
    display: none;
  }

  html.dark .theme-toggle__icon--sun {
    display: none;
  }

  html.dark .theme-toggle__icon--moon {
    display: block;
  }

  .site-header__utility-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 36px;
    padding-inline: 0.875rem;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
    transition:
      color 0.2s ease,
      background-color 0.2s ease;
  }

  .site-header__utility-link:hover,
  .site-header__utility-link:focus-visible {
    color: var(--color-text-base);
    background: var(--color-bg-surface);
  }

  .site-header__menu-button {
    display: none;
    flex-direction: column;
    gap: 0.25rem;
  }

  .site-header__menu-button span {
    display: block;
    width: 1rem;
    height: 1px;
    background: currentColor;
  }

  @media (max-width: 960px) {
    .site-header__middle {
      gap: var(--space-2);
    }

    .site-search__box {
      width: 180px;
    }

    .primary-nav__link {
      padding-inline: 0.6rem;
    }
  }

  @media (max-width: 840px) {
    .site-header__inner {
      justify-content: space-between;
    }

    .site-header__menu-button {
      display: inline-flex;
    }

    .site-header__middle {
      position: absolute;
      top: calc(100% + var(--border-1));
      left: 0;
      right: 0;
      display: none;
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-3);
      padding: var(--space-3);
      border-bottom: var(--border-1) solid var(--color-border);
      background: var(--color-bg-base);
    }

    .site-header__middle.is-open {
      display: flex;
    }

    .primary-nav,
    .primary-nav__list {
      display: block;
    }

    .primary-nav__item + .primary-nav__item {
      margin-top: 0.25rem;
    }

    .primary-nav__link {
      width: 100%;
      justify-content: space-between;
      padding-inline: var(--space-2);
    }

    .primary-nav__dropdown {
      position: static;
      min-width: 0;
      margin-top: 0.25rem;
      padding: 0.25rem;
      border: 0;
      border-radius: var(--radius-md);
      box-shadow: none;
      background: var(--color-bg-surface);
      opacity: 1;
      visibility: visible;
      transform: none;
    }

    .site-search__box {
      width: 100%;
    }
  }

  @media (max-width: 600px) {
    .site-header__inner {
      width: min(100% - 1rem, var(--container-wide, 1440px));
      gap: 0.5rem;
    }

    .site-header__brand {
      font-size: var(--text-base);
    }

    .site-header__utility-link {
      display: none;
    }
  }
</style>
