---
import Logo from "./Logo.astro";
---

<header class="site-header">
  <div class="container header-container">
    <!-- Brand / Logo -->
    <a href="/" class="brand-link" aria-label="Go to CadenceLab homepage">
      <Logo />
      <span class="brand-text">CadenceLab</span>
    </a>

    <!-- Main Navigation -->
    <nav aria-label="Main Navigation" class="desktop-nav">
      <ul class="nav-links">
        <li><a href="/research">Research</a></li>
        <li><a href="/products">Products</a></li>
        <li><a href="/company">Company</a></li>
      </ul>
    </nav>

    <!-- CTA / Action Area -->
    <div class="action-area">
      <a href="/login" class="nav-link-secondary">Log in</a>
      <a href="/contact" class="btn btn-primary">Try Cadence</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    background-color: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(8px);
    border-bottom: var(--border-1) solid var(--color-border);
  }

  .header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px; /* Fixed height for clean grid alignment */
  }

  .brand-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-primary);
  }

  .brand-text {
    font-family: var(--font-sans);
    font-size: var(--text-xl);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-tight);
  }

  .desktop-nav {
    display: none;
  }

  @media (min-width: 768px) {
    .desktop-nav {
      display: block;
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
    }
  }

  .nav-links {
    display: flex;
    gap: var(--space-8);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    color: var(--color-primary);
    font-weight: var(--weight-normal);
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-tight);
  }

  .action-area {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  .nav-link-secondary {
    display: none;
    color: var(--color-primary);
    font-size: var(--text-sm);
    font-weight: var(--weight-normal);
  }

  @media (min-width: 640px) {
    .nav-link-secondary {
      display: block;
    }
  }
</style>
