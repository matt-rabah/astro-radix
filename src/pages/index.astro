---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Matt Rabah"
  description="Customer experience, systems, and implementation work."
>
  <main>
    <!-- Standard Section -->
    <section class="hero-section">
      <div class="container">
        <span class="accent-text">Research Update</span>

        <h1 class="hero-title">Shaping the Future of Intelligent Systems</h1>

        <p class="hero-body">
          This section uses our default typographical hierarchy. The headline
          above is rendered in Tiempos Headline, and this body copy is rendered
          in Graphik.
        </p>
      </div>
    </section>

    <!-- Blog Reversal Section -->
    <section class="blog-preview-section">
      <div class="container">
        <div class="prose-blog">
          <span class="accent-text">Blog Entry</span>

          <h2>The Blog Reversal Rule in Action</h2>

          <p>
            Because this section is wrapped in the <code>.prose-blog</code>
            class, the typography has been completely reversed according to the Harvard
            Business School style guide.
          </p>

          <p>
            Notice how the header above is now rendered in a bold, sturdy
            sans-serif, while this paragraph is set in Tiempos Text for
            long-form readability.
          </p>
        </div>
      </div>
    </section>
  </main>
</Layout>
