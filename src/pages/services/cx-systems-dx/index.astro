---
import Layout from "../../../layouts/Layout.astro";

const title = "CX Systems Diagnostic | Cadence Lab";
const description =
  "A diagnostic for organizations that need to find where customer experience problems are being created across workflows, handoffs, ownership, data, and service operations.";

const signals = [
  "Customers receive inconsistent answers depending on the team, channel, or handoff.",
  "Leadership can see customer friction, but the root cause is still debated internally.",
  "Teams have journey maps, feedback dashboards, or service standards, but the experience has not materially improved.",
  "Escalations repeat because the system rewards workaround behavior instead of fixing the source issue.",
];

const outputs = [
  "A friction map across customer, team, workflow, data, and decision layers.",
  "A handoff and ownership review showing where accountability breaks down.",
  "A root-cause view of what is creating avoidable customer effort.",
  "A prioritized action roadmap organized by customer impact, operational effort, and implementation risk.",
];

const usefulFor = [
  "CX leaders who need a clearer operating diagnosis before funding another initiative.",
  "Customer success, service, or operations teams dealing with recurring escalations.",
  "Organizations preparing to modernize CRM, service workflows, or AI-enabled support.",
  "Teams that need an executive-ready explanation of what is actually breaking the experience.",
];
---

<Layout title={title} description={description}>
  <main class="service-page">
    <section class="service-hero">
      <div class="container">
        <span class="accent-text">Flagship Diagnostic</span>

        <h1>CX Systems Diagnostic</h1>

        <p class="lead">
          For teams that know the customer experience is underperforming, but
          cannot clearly see which part of the operating system is creating the
          problem.
        </p>
      </div>
    </section>

    <section class="service-section service-section--bordered">
      <div class="container service-grid">
        <div>
          <span class="accent-text">Point of View</span>
        </div>

        <div class="service-copy">
          <h2>Most CX problems are not caused by a lack of empathy.</h2>

          <p>
            They are usually caused by unclear ownership, weak handoffs,
            fragmented tools, unreliable customer signals, or decisions being
            made too far away from the customer reality.
          </p>

          <p>
            The CX Systems Diagnostic looks beneath the visible customer journey
            and examines the operating conditions that produce it. The goal is
            not another journey map. The goal is to identify the few system
            changes that would actually improve customer outcomes.
          </p>
        </div>
      </div>
    </section>

    <section class="service-section">
      <div class="container service-grid">
        <div>
          <span class="accent-text">When It Fits</span>
        </div>

        <div class="card-list">
          {signals.map((signal) => <article>{signal}</article>)}
        </div>
      </div>
    </section>

    <section class="service-section service-section--surface">
      <div class="container service-grid">
        <div>
          <span class="accent-text">Outputs</span>
        </div>

        <div class="service-copy">
          <h2>What the diagnostic produces</h2>

          <ul class="check-list">
            {outputs.map((output) => <li>{output}</li>)}
          </ul>
        </div>
      </div>
    </section>

    <section class="service-section">
      <div class="container service-grid">
        <div>
          <span class="accent-text">Best For</span>
        </div>

        <div class="service-copy">
          <ul class="check-list">
            {usefulFor.map((item) => <li>{item}</li>)}
          </ul>

          <a href="/contact/" class="btn btn-primary"
            >Start with this diagnostic</a
          >
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .service-hero {
    padding-block: clamp(var(--space-12), 12vw, var(--space-20));
  }

  .service-hero h1 {
    max-width: 11ch;
  }

  .service-section {
    padding-block: clamp(var(--space-10), 10vw, var(--space-16));
  }

  .service-section--bordered {
    border-top: var(--border-1) solid var(--color-border);
  }

  .service-section--surface {
    background: var(--color-bg-surface);
    border-block: var(--border-1) solid var(--color-border);
  }

  .service-grid {
    display: grid;
    grid-template-columns: minmax(10rem, 0.35fr) minmax(0, 1fr);
    gap: clamp(var(--space-4), 8vw, var(--space-12));
    align-items: start;
  }

  .service-copy {
    max-width: 780px;
  }

  .service-copy h2 {
    max-width: 16ch;
  }

  .service-copy p,
  .service-copy li {
    font-size: clamp(var(--text-lg), 1.8vw, var(--text-xl));
    line-height: var(--leading-relaxed);
  }

  .card-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-3);
  }

  .card-list article {
    padding: var(--space-4);
    border: var(--border-1) solid var(--color-border);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    background: var(--color-bg-base);
  }

  .check-list {
    display: grid;
    gap: var(--space-2);
    margin: 0 0 var(--space-5);
    padding: 0;
    list-style: none;
  }

  .check-list li {
    position: relative;
    padding-left: var(--space-4);
  }

  .check-list li::before {
    content: "";
    position: absolute;
    top: 0.72em;
    left: 0;
    width: 0.45rem;
    height: 0.45rem;
    border-radius: var(--radius-full);
    background: var(--color-accent);
  }

  @media (max-width: 900px) {
    .service-grid,
    .card-list {
      grid-template-columns: 1fr;
    }
  }
</style>
