---
import Layout from "../../../layouts/Layout.astro";

const title = "CRM Workflow Audit | Cadence Lab";
const description =
  "A CRM workflow audit for teams whose CRM activity does not reliably create visibility, accountability, segmentation, or customer action.";

const symptoms = [
  "CRM fields exist, but teams do not trust or consistently use them.",
  "Managers inspect activity, but customer risk and next-best action remain unclear.",
  "Segmentation is technically possible, but not connected to real outreach or service routines.",
  "Customer notes, tasks, and lifecycle status do not translate into reliable operating decisions.",
];

const auditAreas = [
  "Field usage, required data, and actual team behavior.",
  "Customer status, lifecycle, and risk signal clarity.",
  "Account ownership, task logic, and follow-up accountability.",
  "Segmentation and outreach workflows.",
  "Reporting usefulness for managers and frontline teams.",
];

const outputs = [
  "CRM workflow friction map.",
  "Data quality and field-use assessment.",
  "Recommended lifecycle, segmentation, and task logic improvements.",
  "A practical cleanup plan organized by business value and implementation effort.",
];
---

<Layout title={title} description={description}>
  <main class="service-page">
    <section class="service-hero">
      <div class="container">
        <span class="accent-text">CRM and Workflow</span>

        <h1>CRM Workflow Audit</h1>

        <p class="lead">
          For teams whose CRM records activity, but does not reliably drive
          visibility, ownership, or customer action.
        </p>
      </div>
    </section>

    <section class="service-section service-section--bordered">
      <div class="container service-grid">
        <div>
          <span class="accent-text">Point of View</span>
        </div>

        <div class="service-copy">
          <h2>A CRM is not useful because it contains data.</h2>

          <p>
            It is useful when the data is trusted, the workflow matches the
            work, and the system helps teams make better customer decisions at
            the right time.
          </p>

          <p>
            The CRM Workflow Audit looks at the gap between how the CRM was
            designed, how teams actually use it, and what the business needs the
            system to make visible.
          </p>
        </div>
      </div>
    </section>

    <section class="service-section">
      <div class="container service-grid">
        <div>
          <span class="accent-text">Symptoms</span>
        </div>

        <div class="card-list">
          {symptoms.map((symptom) => <article>{symptom}</article>)}
        </div>
      </div>
    </section>

    <section class="service-section service-section--surface">
      <div class="container service-grid">
        <div>
          <span class="accent-text">Audit Areas</span>
        </div>

        <div class="service-copy">
          <h2>What gets examined</h2>

          <ul class="check-list">
            {auditAreas.map((area) => <li>{area}</li>)}
          </ul>
        </div>
      </div>
    </section>

    <section class="service-section">
      <div class="container service-grid">
        <div>
          <span class="accent-text">Outputs</span>
        </div>

        <div class="service-copy">
          <ul class="check-list">
            {outputs.map((output) => <li>{output}</li>)}
          </ul>

          <a href="/contact/" class="btn btn-primary">Audit the workflow</a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .service-hero {
    padding-block: clamp(var(--space-12), 12vw, var(--space-20));
  }

  .service-hero h1 {
    max-width: 12ch;
  }

  .service-section {
    padding-block: clamp(var(--space-10), 10vw, var(--space-16));
  }

  .service-section--bordered {
    border-top: var(--border-1) solid var(--color-border);
  }

  .service-section--surface {
    background: var(--color-bg-surface);
    border-block: var(--border-1) solid var(--color-border);
  }

  .service-grid {
    display: grid;
    grid-template-columns: minmax(10rem, 0.35fr) minmax(0, 1fr);
    gap: clamp(var(--space-4), 8vw, var(--space-12));
    align-items: start;
  }

  .service-copy {
    max-width: 780px;
  }

  .service-copy h2 {
    max-width: 16ch;
  }

  .service-copy p,
  .service-copy li {
    font-size: clamp(var(--text-lg), 1.8vw, var(--text-xl));
    line-height: var(--leading-relaxed);
  }

  .card-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-3);
  }

  .card-list article {
    padding: var(--space-4);
    border: var(--border-1) solid var(--color-border);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    background: var(--color-bg-base);
  }

  .check-list {
    display: grid;
    gap: var(--space-2);
    margin: 0 0 var(--space-5);
    padding: 0;
    list-style: none;
  }

  .check-list li {
    position: relative;
    padding-left: var(--space-4);
  }

  .check-list li::before {
    content: "";
    position: absolute;
    top: 0.72em;
    left: 0;
    width: 0.45rem;
    height: 0.45rem;
    border-radius: var(--radius-full);
    background: var(--color-accent);
  }

  @media (max-width: 900px) {
    .service-grid,
    .card-list {
      grid-template-columns: 1fr;
    }
  }
</style>
